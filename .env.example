# Copy to .env and edit. The lab talks to any OpenAI-compatible endpoint
# (Ollama, llama-server, vLLM, ...).

# Model server
# Ollama on the host (default). From inside Docker use host.docker.internal:
#   MODEL_BASE_URL=http://host.docker.internal:11434/v1
MODEL_BASE_URL=http://localhost:11434/v1
MODEL_NAME=granite4.1:3b
MODEL_API_KEY=ollama

# Vision model (Task 6, optional)
VLM_MODEL_NAME=gemma3:4b

# Scene
SCENE=FloorPlan1
