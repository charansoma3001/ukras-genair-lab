# Task 4: write your own test cases here (one JSON object per line).
# Each case is a command + a check on the world AFTER the robot runs it.
# Lines starting with # are ignored.
#
# Check types:
#   {"held": "Apple"}                                  -> agent is holding an Apple
#   {"held": "nothing"}                                -> agent is holding nothing
#   {"object": "Fridge", "property": "isOpen", "equals": true}
#   Properties you can check: isOpen, isToggled, isSliced, isCooked,
#                             isBroken, isDirty, isFilledWithLiquid, isUsedUp
{"command": "pick up the apple", "check": {"held": "Apple"}}
{"command": "open the fridge", "check": {"object": "Fridge", "property": "isOpen", "equals": true}}
{"command": "turn on the light", "check": {"object": "LightSwitch", "property": "isToggled", "equals": true}}
{"command": "open the microwave", "check": {"object": "Microwave", "property": "isOpen", "equals": true}}
{"command": "slice the bread", "check": {"object": "Bread", "property": "isSliced", "equals": true}}
{"command": "pick up the mug", "check": {"held": "Mug"}}
{"command": "open a cabinet", "check": {"object": "Cabinet", "property": "isOpen", "equals": true}}
{"command": "pick up the tomato", "check": {"held": "Tomato"}}
{"command": "turn on the faucet", "check": {"object": "Faucet", "property": "isToggled", "equals": true}}
{"command": "pick up a knife", "check": {"held": "Knife"}}
